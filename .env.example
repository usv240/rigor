# --- Qwen Cloud / Alibaba Model Studio (DashScope) ---
# Paste your API key below. NOTE: workspace-scoped keys (they start with
# "sk-ws-") come with their OWN endpoint host, shown on the key-creation dialog.
# Use THAT host's /compatible-mode/v1 as the base URL (region ap-southeast-1 =
# Singapore, where the free hackathon credits live).
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://<your-workspace-host>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# Model for reading papers / extracting statistics (long-context Qwen recommended)
QWEN_LLM_MODEL=qwen-plus
